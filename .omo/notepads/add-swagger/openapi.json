  "info": {
    "title": "森花笔记 API",
    "description": "微信公众号驱动的个人笔记系统",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "JWT",
        "description": "请输入 JWT Token",
        "in": "header"
      }
    },
    "schemas": {
      "WechatCallbackDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "微信授权回调 code",
            "example": "081aB6tM0xj3bV1eYz2oM1tLqM0aB6tM"
          }
        },
        "required": ["code"]
      },
      "TokenResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "访问令牌（access_token，2 小时有效）",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "刷新令牌（refresh_token，7 天有效）",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "expiresIn": {
            "type": "number",
            "description": "access_token 过期时间（秒）",
            "example": 7200
          }
        },
        "required": ["accessToken", "refreshToken", "expiresIn"]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "刷新令牌（refresh_token）",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": ["refreshToken"]
      },
      "LogoutResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "登出是否成功",
            "example": true
          }
        },
        "required": ["success"]
      },
      "NoteMediaItemDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "多媒体类型",
            "enum": ["image", "voice", "video", "file"],
            "example": "image"
          },
          "qiniuKey": {
            "type": "string",
            "description": "七牛云存储 Key",
            "example": "notes/2026/07/abc123.jpg"
          },
          "qiniuUrl": {
            "type": "string",
            "description": "七牛云访问 URL",
            "example": "http://cdn.example.com/notes/2026/07/abc123.jpg"
          },
          "fileSize": {
            "type": "number",
            "description": "文件大小（字节）",
            "example": 102400
          },
          "mimeType": {
            "type": "string",
            "description": "MIME 类型",
            "example": "image/jpeg"
          },
          "wxMediaId": {
            "type": "string",
            "description": "微信临时素材 ID",
            "example": "wx_media_abc123"
          }
        },
        "required": ["type", "qiniuKey", "qiniuUrl"]
      },
      "CreateNoteDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "笔记标题，留空时自动从正文截取前 100 字符",
            "example": "我的第一篇笔记"
          },
          "content": {
            "type": "string",
            "description": "笔记正文内容",
            "example": "这是笔记的正文内容..."
          },
          "source": {
            "type": "string",
            "description": "笔记来源",
            "enum": ["wechat", "app_clipboard", "app_manual"],
            "example": "app_manual"
          },
          "categoryId": {
            "type": "string",
            "description": "所属分类 ID",
            "example": "clxyz1234567890abcdef"
          },
          "tagIds": {
            "description": "关联标签 ID 列表",
            "example": ["tag_abc123", "tag_def456"],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "media": {
            "description": "笔记关联的多媒体列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteMediaItemDto"
            }
          }
        }
      },
      "UpdateNoteDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "要更新的笔记 ID",
            "example": "clxyz1234567890abcdef"
          },
          "title": {
            "type": "string",
            "description": "新的笔记标题",
            "example": "更新后的标题"
          },
          "content": {
            "type": "string",
            "description": "新的笔记正文内容",
            "example": "更新后的正文内容..."
          },
          "categoryId": {
            "type": "string",
            "description": "新的分类 ID（传空字符串或省略表示不修改）",
            "example": "clxyz1234567890abcdef"
          },
          "tagIds": {
            "description": "新的标签 ID 列表（传空数组可清空已有标签）",
            "example": ["tag_abc123"],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "media": {
            "description": "笔记关联的多媒体列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteMediaItemDto"
            }
          }
        },
        "required": ["id"]
      },
      "IdDto": {
        "type": "object",
        "properties": {}
      },
      "CategoryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "分类 ID",
            "example": "clxxxxxxxxxxxxxxxx"
          },
          "name": {
            "type": "string",
            "description": "分类名称",
            "example": "工作"
          },
          "parentId": {
            "type": "object",
            "description": "父分类 ID，顶级分类为 null",
            "example": null,
            "nullable": true
          },
          "sortOrder": {
            "type": "number",
            "description": "排序值，数字越小越靠前",
            "example": 0
          },
          "notesCount": {
            "type": "number",
            "description": "该分类下关联的笔记数量",
            "example": 12
          },
          "children": {
            "description": "子分类列表（树形结构）",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CategoryDto"
            }
          }
        },
        "required": ["id", "name", "sortOrder", "notesCount"]
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "分类名称",
            "example": "工作",
            "maxLength": 64
          },
          "parentId": {
            "type": "string",
            "description": "父分类 ID，顶层分类可不传；最多 3 层嵌套",
            "example": "clxxxxxxxxxxxxxxxx",
            "nullable": true
          }
        },
        "required": ["name"]
      },
      "UpdateCategoryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "要更新的分类 ID",
            "example": "clxxxxxxxxxxxxxxxx"
          },
          "name": {
            "type": "string",
            "description": "新的分类名称",
            "example": "学习",
            "maxLength": 64
          },
          "parentId": {
            "type": "string",
            "description": "新的父分类 ID，传 null 表示升级为顶层；不能设为自身或自身子孙",
            "example": "clxxxxxxxxxxxxxxxx",
            "nullable": true
          }
        },
        "required": ["id"]
      },
      "ReorderItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "被排序的分类 ID",
            "example": "clxxxxxxxxxxxxxxxx"
          },
          "parentId": {
            "type": "object",
            "description": "新的父分类 ID；null 表示移动到顶层",
            "example": null,
            "nullable": true
          }
        },
        "required": ["id"]
      },
      "ReorderCategoryDto": {
        "type": "object",
        "properties": {
          "items": {
            "description": "排序项列表，数组下标即新的 sortOrder 值",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReorderItem"
            }
          }
        },
        "required": ["items"]
      },
      "TagResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "标签 ID（UUID）",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "name": {
            "type": "string",
            "description": "标签名称",
            "example": "随笔"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "创建时间",
            "example": "2026-07-03T10:00:00.000Z"
          },
          "_count": {
            "type": "object",
            "description": "关联笔记数量（仅 list 接口返回）",
            "example": 5
          }
        },
        "required": ["id", "name", "createdAt"]
      },
      "CreateTagDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "标签名称",
            "maxLength": 32,
            "example": "随笔"
          }
        },
        "required": ["name"]
      },
      "UploadTokenResponseDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "七牛云直传凭证 Token（有效期 1 小时，App 端使用该 Token 走直传）",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzY29wZSI6InNlbmh1YS1ub3RlcyIsImRlYWRsaW5lIjoxNzMyNDM2NDAwfQ.signature"
          }
        },
        "required": ["token"]
      },
      "DeleteFileDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "七牛云文件 key",
            "example": "notes/2026/07/image.jpg"
          }
        },
        "required": ["key"]
      },
      "DeleteFileResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "七牛云侧文件是否删除成功（true=成功，false=失败）",
            "example": true
          }
        },
        "required": ["success"]
      },
      "UploadFileResponseDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "文件在七牛云存储的 Key（唯一标识，后续可用于访问或删除）",
            "example": "notes/2026/07/abc123.jpg"
          },
          "url": {
            "type": "string",
            "description": "文件公开访问 URL（七牛云 CDN 域名拼接）",
            "example": "http://cdn.example.com/notes/2026/07/abc123.jpg"
          },
          "mimeType": {
            "type": "string",
            "description": "文件 MIME 类型（如 image/jpeg、video/mp4）",
            "example": "image/jpeg"
          },
          "size": {
            "type": "number",
            "description": "文件大小（字节）",
            "example": 204800
          }
        },
        "required": ["key", "url", "mimeType", "size"]
      }
    }
  }
}
