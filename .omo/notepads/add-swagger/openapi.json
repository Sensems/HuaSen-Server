{
  "openapi": "3.0.0",
  "paths": {
    "/auth/wechat/callback": {
      "post": {
        "operationId": "AuthController_wechatLogin",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WechatCallbackDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功，返回 access_token 与 refresh_token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "微信授权失败（code 无效或已过期）"
          }
        },
        "summary": "微信 OAuth 登录",
        "tags": ["认证"]
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "刷新成功，返回新的 access_token 与 refresh_token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "refresh_token 无效或已过期"
          }
        },
        "summary": "刷新 access_token",
        "tags": ["认证"]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "200": {
            "description": "登出成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "未登录或 token 无效"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "登出（将当前 token 加入黑名单）",
        "tags": ["认证"]
      }
    },
    "/notes": {
      "get": {
        "operationId": "NotesController_list",
        "parameters": [
          {
            "name": "type",
            "required": false,
            "in": "query",
            "description": "笔记类型筛选（draft/published/archived）",
            "schema": {
              "example": "published",
              "type": "string"
            }
          },
          {
            "name": "category",
            "required": false,
            "in": "query",
            "description": "按分类 ID 筛选",
            "schema": {
              "example": "clxyz1234567890abcdef",
              "type": "string"
            }
          },
          {
            "name": "tag",
            "required": false,
            "in": "query",
            "description": "按标签 ID 筛选（命中关联该标签的笔记）",
            "schema": {
              "example": "tag_abc123",
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "required": false,
            "in": "query",
            "description": "关键词模糊搜索（匹配标题或正文）",
            "schema": {
              "example": "森花笔记",
              "type": "string"
            }
          },
          {
            "name": "mediaType",
            "required": false,
            "in": "query",
            "description": "按媒体类型筛选",
            "schema": {
              "example": "IMAGE",
              "type": "string",
              "enum": ["IMAGE", "VOICE", "VIDEO", "FILE"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回分页后的笔记列表"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "获取笔记列表（分页 + 筛选）",
        "tags": ["笔记"]
      }
    },
