    "/wechat/callback": {
      "get": {
        "operationId": "WechatController_verify",
        "parameters": [
          {
            "name": "echostr",
            "required": true,
            "in": "query",
            "description": "随机字符串，验证通过时原样返回",
            "schema": {}
          },
          {
            "name": "nonce",
            "required": true,
            "in": "query",
            "description": "随机数",
            "schema": {}
          },
          {
            "name": "timestamp",
            "required": true,
            "in": "query",
            "description": "时间戳",
            "schema": {}
          },
          {
            "name": "signature",
            "required": true,
            "in": "query",
            "description": "微信加密签名（sha1(token + timestamp + nonce)）",
            "schema": {}
          }
        ],
        "responses": {
          "200": {
            "description": "验证成功时原样返回 echostr；验证失败时返回字符串 \"verification failed\"（纯文本，非 JSON）"
          }
        },
        "summary": "微信服务器 URL 验证（GET 回调）",
        "tags": ["微信"]
      },
      "post": {
        "operationId": "WechatController_receive",
        "parameters": [],
        "responses": {
          "200": {
            "description": "处理完成后必须返回纯文本 \"success\"（微信服务器要求，不能返回 JSON，失败时也返回 success 由 Worker 重试）"
          }
        },
        "summary": "接收微信消息事件（POST 回调）",
        "tags": ["微信"]
      }
    },
